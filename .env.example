# JobTracker Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# NUWorks (Northeastern University Career Portal)
# =============================================================================
# Your Northeastern University credentials for NUWorks access
NUWORKS_USERNAME=your.email@northeastern.edu
NUWORKS_PASSWORD=your_password

# =============================================================================
# Adzuna API (Optional)
# =============================================================================
# Get free API credentials at: https://developer.adzuna.com/
# Adzuna aggregates jobs from multiple sources
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# =============================================================================
# User Profile
# =============================================================================
# Path to your resume (used for reference, not uploaded anywhere)
RESUME_PATH=C:/Users/YourName/Documents/resume.pdf

# Your GitHub profile URL
GITHUB_URL=https://github.com/yourusername

# =============================================================================
# Application Settings
# =============================================================================
# Flask secret key (generate a random string for production)
SECRET_KEY=your-secret-key-change-in-production

# Database URL (default: SQLite in instance folder)
# DATABASE_URL=sqlite:///jobs.db

# Server port (default: 8080)
# PORT=8080
